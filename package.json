{
  "name": "@controlla-io/starto",
  "version": "0.1.5",
  "description": "Develop and run multiple branches simultaneously — lightweight, isolated servers, databases, and ports",
  "type": "module",
  "bin": {
    "starto": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "prepublishOnly": "tsc && npm test"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "dev",
    "worktree",
    "parallel",
    "environment",
    "ports",
    "database",
    "local-dev",
    "git-worktree",
    "monorepo",
    "developer-tools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/controlla-io/starto.git"
  },
  "homepage": "https://github.com/controlla-io/starto",
  "author": "Controlla <hello@controlla.io>",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
